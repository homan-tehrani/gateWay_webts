LOG_URL=https://loger.sirafgroup.com/api/save-log
CACHE_TIME=108000
CACHE_IP_ADDRESS=cache
DB_NAME=Urls.db
TOKEN=test
AUTHENTICATION_SITE=https://nativeauth.sirafgroup.com
RABBITMQ_HOST=77.238.120.201
RABBITMQ_URL=77.238.120.201
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=admin
RABBITMQ_PASSWORD=admin
RABBITMQ_VHOST=gateway
RABBIT_EXCHANGE_NAME=logs

RESOURCE_TOKEN=a9F23112kP72
GROUP_PROJECT_ID=1
APIS_FOR_GATEWAY=https://api.basynergy.ir/api/api/apisForGateway/

# ----- Logging system -----
# Master switches
DO_LOG=1
LOG_TO_RABBITMQ=1
LOG_TO_SENTRY=0

# Status codes that trigger a log. Supports single codes and ranges.
# Example: "404,429,500-599"
LOG_STATUS_CODES=404,429,500-599,205

# Routing key for published log messages
LOG_ROUTING_KEY=requests_logs

# Bounded in-memory queue size (logs are dropped if full -- fail-open)
LOG_QUEUE_MAXSIZE=10000

# Max bytes of request/response body included per log message
LOG_BODY_MAX_BYTES=4096

# Headers redacted in logs (comma separated, lowercase)
#LOG_SENSITIVE_HEADERS=authorization,cookie,set-cookie,x-api-key,proxy-authorization
LOG_SENSITIVE_HEADERS=cookie,set-cookie,x-api-key,proxy-authorization

# Optional: map project_name or upstream host -> docker container name
# so 5xx logs include container status/logs.
# Example: {"orders-service": "orders_api_1", "10.0.0.5": "auth_api_1"}
CONTAINER_MAP=


# TTL seconds for cached container inspection (protects docker daemon)
CONTAINER_INFO_TTL=30
